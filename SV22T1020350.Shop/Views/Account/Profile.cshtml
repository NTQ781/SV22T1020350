@model SV22T1020350.Models.Partner.Customer
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="row mt-4 mb-5 g-4">
    <div class="col-md-3">
        @* --- Menu bên trái giữ nguyên --- *@
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-top" style="top: 100px;">
            <div class="bg-primary bg-opacity-10 p-4 text-center border-bottom border-primary border-opacity-25">
                <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center shadow-sm mb-2" style="width: 70px; height: 70px;">
                    <i class="bi bi-person-check-fill text-primary fs-1"></i>
                </div>
                <h6 class="fw-bold text-dark mb-0">@Model.CustomerName</h6>
                <small class="text-muted">ID: #@Model.CustomerID</small>
            </div>
            <div class="list-group list-group-flush border-0">
                <a href="~/Account/Profile" class="list-group-item list-group-item-action py-3 border-0 active bg-primary text-white fw-semibold">
                    <i class="bi bi-person-lines-fill me-2"></i> Hồ sơ cá nhân
                </a>
                <a href="~/Order/History" class="list-group-item list-group-item-action py-3 border-0">
                    <i class="bi bi-clock-history text-secondary me-2"></i> Đơn hàng của tôi
                </a>
                <a href="~/Account/ChangePassword" class="list-group-item list-group-item-action py-3 border-0">
                    <i class="bi bi-shield-lock text-secondary me-2"></i> Đổi mật khẩu
                </a>
                <a href="~/Account/Logout" class="list-group-item list-group-item-action py-3 border-0 text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <h4 class="mb-4 text-slate fw-bold pb-3 border-bottom">THÔNG TIN TÀI KHOẢN</h4>

            @* Hiển thị thông báo thành công *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Hiển thị thông báo lỗi *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form action="~/Account/UpdateProfile" method="post" class="row g-4">
                @* Cực kỳ quan trọng: Gửi ID ẩn lên server *@
                <input type="hidden" name="CustomerID" value="@Model.CustomerID" />

                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold text-uppercase">Họ và tên khách hàng</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-secondary"><i class="bi bi-person"></i></span>
                        <input type="text" class="form-control bg-light border-start-0" value="@Model.CustomerName" readonly>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold text-uppercase">Email đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-secondary"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control bg-light border-start-0" value="@Model.Email" readonly>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold text-uppercase">Số điện thoại liên hệ</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-secondary"><i class="bi bi-telephone"></i></span>
                        <input type="text" name="Phone" class="form-control border-start-0" value="@Model.Phone" required>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold text-uppercase">Tỉnh / Thành phố</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-secondary"><i class="bi bi-map"></i></span>
                        <input type="text" name="Province" class="form-control border-start-0" value="@Model.Province" required>
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label text-muted small fw-bold text-uppercase">Địa chỉ nhận hàng mặc định</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-secondary"><i class="bi bi-geo-alt"></i></span>
                        <textarea name="Address" class="form-control border-start-0" rows="2" required>@Model.Address</textarea>
                    </div>
                </div>

                <div class="col-12 mt-5">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                        CẬP NHẬT THÔNG TIN
                    </button>
                    <p class="text-muted small mt-3"><i class="bi bi-info-circle me-1"></i> Thông tin Email và Họ tên không thể tự thay đổi. Vui lòng liên hệ Admin nếu có sai sót.</p>
                </div>
            </form>
        </div>
    </div>
</div>