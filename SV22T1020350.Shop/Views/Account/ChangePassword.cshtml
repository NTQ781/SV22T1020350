@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row mt-4 mb-5 g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-top" style="top: 100px;">
            <div class="bg-primary bg-opacity-10 p-4 text-center border-bottom border-primary border-opacity-25">
                <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center shadow-sm mb-2" style="width: 70px; height: 70px;">
                    <i class="bi bi-shield-lock-fill text-primary fs-1"></i>
                </div>
                <h6 class="fw-bold text-dark mb-0">@User.Identity?.Name</h6>
                <small class="text-muted">Bảo mật tài khoản</small>
            </div>
            <div class="list-group list-group-flush border-0">
                <a href="~/Account/Profile" class="list-group-item list-group-item-action py-3 border-0">
                    <i class="bi bi-person-lines-fill text-secondary me-2"></i> Hồ sơ cá nhân
                </a>
                <a href="~/Order/History" class="list-group-item list-group-item-action py-3 border-0">
                    <i class="bi bi-clock-history text-secondary me-2"></i> Đơn hàng của tôi
                </a>
                <a href="~/Account/ChangePassword" class="list-group-item list-group-item-action py-3 border-0 active bg-primary text-white fw-semibold">
                    <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
                </a>
                <a href="~/Account/Logout" class="list-group-item list-group-item-action py-3 border-0 text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <h4 class="mb-4 text-slate fw-bold pb-3 border-bottom">
                <i class="bi bi-key-fill text-warning me-2"></i>ĐỔI MẬT KHẨU
            </h4>

            @if (!string.IsNullOrEmpty(ViewBag.Message))
            {
                <div class="alert alert-warning alert-dismissible fade show border-0 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i> @Html.Raw(ViewBag.Message)
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form action="~/Account/ChangePassword" method="post" class="row g-4 mt-1">
                <div class="col-md-8">
                    <label class="form-label text-muted small fw-bold text-uppercase">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0 text-secondary"><i class="bi bi-unlock"></i></span>
                        <input type="password" name="oldPassword" class="form-control border-start-0" required placeholder="Nhập mật khẩu cũ...">
                    </div>
                </div>

                <div class="col-md-8">
                    <label class="form-label text-muted small fw-bold text-uppercase">Mật khẩu mới <span class="text-danger">*</span></label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0 text-secondary"><i class="bi bi-lock"></i></span>
                        <input type="password" name="newPassword" class="form-control border-start-0" required placeholder="Tối thiểu 6 ký tự..." minlength="6">
                    </div>
                </div>

                <div class="col-md-8">
                    <label class="form-label text-muted small fw-bold text-uppercase">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0 text-secondary"><i class="bi bi-check2-circle"></i></span>
                        <input type="password" name="confirmPassword" class="form-control border-start-0" required placeholder="Nhập lại mật khẩu mới..." minlength="6">
                    </div>
                </div>

                <div class="col-12 mt-5">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                        XÁC NHẬN ĐỔI MẬT KHẨU
                    </button>
                    <p class="text-muted small mt-3 italic"><i class="bi bi-shield-check text-success me-1"></i> Vui lòng không chia sẻ mật khẩu cho bất kỳ ai để đảm bảo an toàn tài khoản.</p>
                </div>
            </form>
        </div>
    </div>
</div>