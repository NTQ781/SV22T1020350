@model IEnumerable<SV22T1020350.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h4 class="fw-bold m-0 text-slate"><i class="bi bi-cart3 text-primary me-2"></i>GIỎ HÀNG CỦA BẠN</h4>
    @if (Model.Any())
    {
        @* Đã sửa: Thêm open-modal *@
        <a href="/Cart/Clear" class="btn btn-outline-danger btn-sm rounded-pill px-3 open-modal">
            <i class="bi bi-trash"></i> Xóa tất cả
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
        <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" style="width: 120px; opacity: 0.5;" class="mb-3" />
        <h5 class="text-muted">Giỏ hàng của bạn đang trống!</h5>
        <a href="/" class="btn btn-primary rounded-pill px-5 mt-3">Tiếp tục mua sắm</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="cartTable">
                        <thead class="table-light text-muted small text-uppercase">
                            <tr>
                                <th width="40" class="ps-4"><input type="checkbox" class="form-check-input" id="selectAll"></th>
                                <th>Sản phẩm</th>
                                <th class="text-center" width="150">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end pe-4">Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr data-id="@item.ProductID" data-price="@item.Price">
                                    <td class="ps-4"><input type="checkbox" class="form-check-input item-check"></td>
                                    <td>
                                        <div class="d-flex align-items-center py-2">
                                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "demo.png" : item.Photo)"
                                                 class="rounded border bg-light me-3" style="width: 60px; height: 60px; object-fit: contain;">
                                            <div class="fw-semibold text-dark line-clamp-2">@item.ProductName</div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="input-group input-group-sm justify-content-center">
                                            <button class="btn btn-outline-secondary btn-minus px-2">-</button>
                                            <input type="text" class="form-control text-center qty-input fw-bold bg-white" value="@item.Quantity" style="max-width: 50px" readonly>
                                            <button class="btn btn-outline-secondary btn-plus px-2">+</button>
                                        </div>
                                    </td>
                                    <td class="text-end text-muted">@item.Price.ToString("N0")</td>
                                    <td class="text-end fw-bold text-danger pe-4 item-total">@item.TotalPrice.ToString("N0")</td>
                                    <td class="text-center pe-3"><a href="/Cart/Remove/@item.ProductID" class="text-secondary hover-danger"><i class="bi bi-trash fs-5"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm rounded-4 p-4 bg-summary sticky-top" style="top: 100px">
                <h5 class="fw-bold text-primary mb-4 pb-2 border-bottom border-primary border-opacity-25">TÓM TẮT ĐƠN HÀNG</h5>
                <div class="d-flex justify-content-between mb-3 text-secondary">
                    <span>Số sản phẩm đã chọn:</span>
                    <span id="selectedCount" class="fw-bold text-dark">0</span>
                </div>
                <div class="d-flex justify-content-between mb-4 border-top pt-3">
                    <span class="fs-5 text-dark fw-semibold">Tổng tiền:</span>
                    <span class="fs-4 fw-bold text-danger" id="grandTotal">0 đ</span>
                </div>
                <button class="btn btn-primary w-100 btn-lg rounded-pill fw-bold shadow-sm" id="btnCheckout" disabled>
                    MUA HÀNG NGAY <i class="bi bi-arrow-right ms-2"></i>
                </button>
                <p class="text-center text-muted small mt-3 mb-0"><i class="bi bi-shield-lock"></i> Thanh toán an toàn & bảo mật</p>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function calculateTotal() {
            let total = 0, count = 0;
            $(".item-check:checked").each(function() {
                let row = $(this).closest("tr");
                total += parseFloat(row.data("price")) * parseInt(row.find(".qty-input").val());
                count++;
            });
            $("#grandTotal").text(total.toLocaleString('vi-VN') + " đ");
            $("#selectedCount").text(count);
            $("#btnCheckout").prop("disabled", count === 0);
        }

        $("#selectAll").click(function() { $(".item-check").prop("checked", $(this).prop("checked")); calculateTotal(); });
        $(document).on("change", ".item-check", calculateTotal);

        $(".btn-plus, .btn-minus").click(function() {
            let row = $(this).closest("tr");
            let id = row.data("id"), input = row.find(".qty-input"), current = parseInt(input.val());
            let newQty = $(this).hasClass("btn-plus") ? current + 1 : current - 1;
            if (newQty >= 1) {
                $.post("/Cart/UpdateQuantity", { id: id, quantity: newQty }, function(res) {
                    if(res.success) {
                        input.val(newQty);
                        row.find(".item-total").text(res.itemTotal);
                        if(typeof updateCartBadge === 'function') updateCartBadge();
                        calculateTotal();
                    }
                });
            }
        });

        $("#btnCheckout").click(function() {
            let selectedIds = [];
            $(".item-check:checked").each(function() { selectedIds.push($(this).closest("tr").data("id")); });
            if (selectedIds.length > 0) {
                let url = "/Order/Checkout?" + selectedIds.map(id => "selectedIds=" + id).join("&");
                window.location.href = url;
            }
        });
    </script>
}