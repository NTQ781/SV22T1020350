@{
    Layout = null;
}
<form action="/Cart/Clear" method="post" class="ajax-form">
    <div class="modal-header text-bg-danger">
        <strong class="modal-title"><i class="bi bi-trash me-2"></i>Xác nhận làm trống giỏ hàng</strong>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body text-center py-4">
        <div class="mb-3">
            <i class="bi bi-exclamation-triangle text-warning" style="font-size: 3rem;"></i>
        </div>
        <h5 class="fw-bold">Bạn có chắc chắn?</h5>
        <p class="text-muted mb-0">Tất cả sản phẩm trong giỏ hàng sẽ bị xóa sạch.</p>
    </div>
    <div class="modal-footer justify-content-center border-0">
        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">ĐỒNG Ý XÓA</button>
        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">HỦY BỎ</button>
    </div>
</form>