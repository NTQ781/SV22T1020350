@{
    ViewData["Title"] = "Xác nhận đặt hàng";
    var items = ViewBag.CheckoutItems as List<SV22T1020350.Shop.Models.CartItem>;
    var customer = ViewBag.Customer as SV22T1020350.Models.Partner.Customer;
    decimal total = items.Sum(i => i.TotalPrice);
}

<div class="container py-4">
    @* HIỂN THỊ THÔNG BÁO LỖI TỪ HỆ THỐNG *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>
            <strong>Thông báo:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white" style="border-top: 4px solid var(--accent-color) !important;">
                <h5 class="fw-bold text-slate mb-4 pb-2 border-bottom"><i class="bi bi-geo-alt-fill text-danger me-2"></i>THÔNG TIN GIAO HÀNG</h5>
                <form action="/Order/PlaceOrder" method="post" id="checkoutForm">
                    @foreach (var item in items)
                    {
                        <input type="hidden" name="productIds" value="@item.ProductID" />
                    }

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Người nhận</label>
                        <input type="text" class="form-control bg-light text-secondary" value="@customer?.CustomerName - @customer?.Phone" readonly>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                            <input type="text" name="deliveryProvince" class="form-control border-secondary-subtle" required value="@customer?.Province">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold">Số điện thoại dự phòng</label>
                            <input type="text" class="form-control border-secondary-subtle" placeholder="Không bắt buộc">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Địa chỉ chi tiết <span class="text-danger">*</span></label>
                        <textarea name="deliveryAddress" class="form-control border-secondary-subtle" rows="2" required>@customer?.Address</textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Ghi chú đơn hàng</label>
                        <textarea name="notes" class="form-control border-secondary-subtle" rows="2" placeholder="Giao giờ hành chính, gọi trước khi giao..."></textarea>
                    </div>

                    <h5 class="fw-bold text-slate mb-3 pt-3 border-top"><i class="bi bi-credit-card-2-front text-primary me-2"></i>PHƯƠNG THỨC THANH TOÁN</h5>

                    <div class="form-check mb-3 p-3 border rounded-3 bg-light cursor-pointer payment-box">
                        <input class="form-check-input ms-1 me-2 payment-method" type="radio" name="paymentMethod" value="COD" id="payCOD" checked>
                        <label class="form-check-label fw-bold w-100 cursor-pointer" for="payCOD">
                            <i class="bi bi-cash text-success fs-5 me-2 align-middle"></i> Thanh toán tiền mặt khi nhận hàng (COD)
                        </label>
                    </div>

                    <div class="form-check p-3 border rounded-3 bg-light cursor-pointer payment-box">
                        <input class="form-check-input ms-1 me-2 payment-method" type="radio" name="paymentMethod" value="Transfer" id="payTransfer">
                        <label class="form-check-label fw-bold w-100 cursor-pointer" for="payTransfer">
                            <i class="bi bi-qr-code-scan text-primary fs-5 me-2 align-middle"></i> Chuyển khoản qua mã QR
                        </label>
                    </div>

                    <div id="qrCodeSection" class="mt-3 text-center d-none p-4 border rounded-3 shadow-sm bg-white">
                        <h6 class="fw-bold text-primary mb-2">QUÉT MÃ ĐỂ THANH TOÁN</h6>
                        <p class="small text-muted mb-3">Mở ứng dụng ngân hàng và quét mã dưới đây.</p>
                        <img src="https://img.vietqr.io/image/vcb-123456789-compact2.png?amount=@total&addInfo=Thanh toan don hang NTQ Shop"
                             alt="QR Code" class="img-fluid rounded border p-2" style="max-width: 200px;">
                        <p class="small text-danger mt-3 fw-bold mb-0"><i class="bi bi-exclamation-triangle"></i> Vui lòng không thay đổi nội dung chuyển khoản!</p>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm mt-4">
                        XÁC NHẬN ĐẶT HÀNG
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                <h5 class="fw-bold mb-4 text-slate pb-2 border-bottom"><i class="bi bi-receipt text-secondary me-2"></i>ĐƠN HÀNG CỦA BẠN</h5>

                <div class="pe-2 mb-3">
                    @foreach (var item in items)
                    {
                        <div class="d-flex align-items-center mb-3 pb-3 border-bottom border-light">
                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "demo.png" : item.Photo)"
                                 class="rounded border bg-light me-3" style="width: 60px; height: 60px; object-fit: contain;">
                            <div class="flex-grow-1">
                                <div class="fw-semibold small text-dark line-clamp-2">@item.ProductName</div>
                                <div class="text-muted small mt-1">SL: @item.Quantity</div>
                            </div>
                            <div class="fw-bold text-danger ms-3">@item.TotalPrice.ToString("N0") đ</div>
                        </div>
                    }
                </div>

                <div class="bg-light p-3 rounded-3 mt-2">
                    <div class="d-flex justify-content-between text-muted small mb-2">
                        <span>Tạm tính:</span>
                        <span>@total.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted small mb-2">
                        <span>Phí vận chuyển:</span>
                        <span class="text-success fw-semibold">Miễn phí</span>
                    </div>
                    <hr class="my-2 border-secondary-subtle">
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="fs-5 fw-bold text-dark">TỔNG CỘNG:</span>
                        <span class="fs-4 fw-bold text-danger">@total.ToString("N0") đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(".payment-method").change(function() {
            if ($("#payTransfer").is(":checked")) {
                $("#qrCodeSection").removeClass("d-none").hide().fadeIn(300);
            } else {
                $("#qrCodeSection").fadeOut(200, function() { $(this).addClass("d-none"); });
            }
        });

        $(".payment-box").click(function() {
            $(this).find("input[type='radio']").prop("checked", true).trigger("change");
        });
    </script>
}