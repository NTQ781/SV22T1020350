@model IEnumerable<SV22T1020350.Models.Sales.OrderViewInfo>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="row mt-4 mb-5 g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-top" style="top: 100px;">
            <div class="bg-primary bg-opacity-10 p-4 text-center border-bottom border-primary border-opacity-25">
                <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center shadow-sm mb-2" style="width: 70px; height: 70px;">
                    <i class="bi bi-person-fill text-primary fs-1"></i>
                </div>
                <h6 class="fw-bold text-dark mb-0">@User.Identity?.Name</h6>
                <small class="text-muted">Khách hàng thành viên</small>
            </div>
            <div class="list-group list-group-flush border-0">
                <a href="~/Account/Profile" class="list-group-item list-group-item-action py-3 border-0"><i class="bi bi-person-lines-fill text-secondary me-2"></i> Hồ sơ cá nhân</a>
                <a href="~/Order/History" class="list-group-item list-group-item-action py-3 border-0 active bg-primary text-white fw-semibold"><i class="bi bi-clock-history me-2"></i> Đơn hàng của tôi</a>
                <a href="~/Account/Logout" class="list-group-item list-group-item-action py-3 border-0 text-danger"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <h4 class="mb-4 text-slate fw-bold pb-3 border-bottom"><i class="bi bi-bag-check-fill text-success me-2"></i>ĐƠN HÀNG CỦA TÔI</h4>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" style="width: 120px; opacity: 0.5;" class="mb-3" />
                    <h5 class="text-muted fw-bold">Bạn chưa có đơn hàng nào</h5>
                    <p class="text-secondary small">Hãy khám phá các sản phẩm tuyệt vời của NTQ Shop nhé!</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4 mt-2">Bắt đầu mua sắm</a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-4">
                    @foreach (var order in Model)
                    {
                        <div class="card border border-secondary-subtle rounded-4 shadow-sm hover-shadow transition-all">
                            <div class="card-header bg-light border-bottom border-secondary-subtle p-3 d-flex justify-content-between align-items-center flex-wrap gap-2 rounded-top-4">
                                <div class="fw-bold text-dark">
                                    <span class="text-muted fw-normal me-1">Mã đơn:</span> <span class="text-primary fs-5">#@order.OrderID</span>
                                </div>
                                <div>
                                    @if ((int)order.Status == 1)
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                    }
                                    else if ((int)order.Status == 2)
                                    {

                                        <span class="badge bg-info text-white px-3 py-2 rounded-pill"><i class="bi bi-check2-circle me-1"></i> Đã duyệt</span>
                                    }
                                    else if ((int)order.Status == 3)
                                    {

                                        <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="bi bi-truck me-1"></i> Đang giao</span>
                                    }
                                    else if ((int)order.Status == 4)
                                    {

                                        <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-box-seam me-1"></i> Hoàn tất</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i> Đã hủy</span>
                                    }
                                </div>
                            </div>

                            <div class="card-body p-4">
                                <div class="row align-items-center">
                                    <div class="col-md-8 mb-3 mb-md-0">
                                        <div class="d-flex mb-2">
                                            <div class="text-muted small" style="width: 100px;"><i class="bi bi-calendar3 me-1"></i> Ngày đặt:</div>
                                            <div class="fw-semibold text-dark">@order.OrderTime.ToString("dd/MM/yyyy - HH:mm")</div>
                                        </div>
                                        <div class="d-flex mb-2">
                                            <div class="text-muted small" style="width: 100px;"><i class="bi bi-person-vcard me-1"></i> Người nhận:</div>
                                            <div class="text-dark">@order.CustomerName</div>
                                        </div>
                                        <div class="d-flex">
                                            <div class="text-muted small" style="width: 100px;"><i class="bi bi-geo-alt me-1"></i> Giao đến:</div>
                                            <div class="text-secondary small line-clamp-2">@order.DeliveryAddress, @order.DeliveryProvince</div>
                                        </div>
                                    </div>
                                    <div class="col-md-4 text-md-end text-start border-md-start ps-md-4">
                                        <a href="/Order/Details/@order.OrderID" class="btn btn-outline-primary rounded-pill px-4 shadow-sm fw-semibold w-100 w-md-auto">
                                            Xem chi tiết <i class="bi bi-chevron-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>