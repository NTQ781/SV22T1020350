@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 text-center">
        <div class="card border-0 shadow-sm rounded-4 p-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            <h3 class="fw-bold mt-4 text-slate">ĐẶT HÀNG THÀNH CÔNG!</h3>
            <p class="text-muted fs-5 mt-2">Mã đơn hàng của bạn là: <b class="text-primary">#@ViewBag.OrderID</b></p>
            <p class="text-muted">Cảm ơn bạn đã tin tưởng và mua sắm tại NTQ Shop. Chúng tôi sẽ sớm liên hệ để giao hàng cho bạn.</p>

            <div class="mt-5 d-flex gap-3 justify-content-center">
                <a href="/Order/History" class="btn btn-outline-primary rounded-pill px-4">Xem đơn hàng</a>
                <a href="/" class="btn btn-primary rounded-pill px-4">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</div>