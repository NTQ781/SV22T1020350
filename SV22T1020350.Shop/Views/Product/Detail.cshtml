@model SV22T1020350.Models.Catalog.Product
@{
    ViewData["Title"] = Model.ProductName;
    var photos = ViewBag.Photos as IEnumerable<SV22T1020350.Models.Catalog.ProductPhoto>;
    var attributes = ViewBag.Attributes as IEnumerable<SV22T1020350.Models.Catalog.ProductAttribute>;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-secondary">Trang chủ</a></li>
        <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-secondary">Sản phẩm</a></li>
        <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@Model.ProductName</li>
    </ol>
</nav>

<div class="row g-5 mb-5">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
            <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "demo.png" : Model.Photo)"
                             class="d-block w-100" style="height: 400px; object-fit: contain;" alt="Main">
                    </div>
                    @if (photos != null)
                    {
                        foreach (var p in photos)
                        {
                            <div class="carousel-item">
                                <img src="~/images/products/@p.Photo" class="d-block w-100" style="height: 400px; object-fit: contain;">
                            </div>
                        }
                    }
                </div>
                @if (photos?.Any() == true)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon bg-dark rounded-circle p-2" aria-hidden="true"></span>
                    </button>
                }
            </div>
            <div class="d-flex gap-2 mt-3 justify-content-center overflow-auto pb-2">
                <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "demo.png" : Model.Photo)"
                     class="rounded border p-1 border-primary" style="width: 60px; height: 60px; object-fit: cover; cursor: pointer;">
                @if (photos != null)
                {
                    foreach (var p in photos)
                    {
                        <img src="~/images/products/@p.Photo" class="rounded border p-1" style="width: 60px; height: 60px; object-fit: cover; cursor: pointer;">
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="ps-md-3">
            <h2 class="fw-bold text-slate mb-2">@Model.ProductName</h2>
            <div class="mb-4">
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2"><i class="bi bi-check-circle me-1"></i> Đang kinh doanh</span>
                <span class="text-muted ms-3 small">Đơn vị tính: <b>@Model.Unit</b></span>
            </div>

            <div class="bg-light p-4 rounded-4 border mb-4 shadow-sm">
                <div class="text-muted small text-uppercase fw-bold mb-1">Giá bán lẻ niêm yết:</div>
                <div class="text-danger fw-bold fs-1">@Model.Price.ToString("N0") <small class="fs-4">đ</small></div>
            </div>

            <div class="mb-4">
                <label class="fw-bold text-dark mb-2">Số lượng đặt mua:</label>
                <div class="input-group shadow-sm" style="width: 150px;">
                    <button class="btn btn-outline-secondary px-3" type="button" onclick="changeQty(-1)">-</button>
                    <input type="number" id="detailQty" class="form-control text-center fw-bold" value="1" min="1">
                    <button class="btn btn-outline-secondary px-3" type="button" onclick="changeQty(1)">+</button>
                </div>
            </div>

            <div class="d-grid gap-3 d-md-flex mt-5">
                <button type="button" onclick="handleAddToCart()" class="btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow">
                    <i class="bi bi-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                </button>
                <button type="button" class="btn btn-outline-danger btn-lg px-4 rounded-pill fw-bold">
                    <i class="bi bi-heart"></i>
                </button>
            </div>

            <div class="mt-5 border-top pt-4 row text-center g-3">
                <div class="col-4">
                    <i class="bi bi-truck fs-3 text-primary"></i>
                    <div class="small text-muted mt-1">Giao hàng toàn quốc</div>
                </div>
                <div class="col-4">
                    <i class="bi bi-shield-check fs-3 text-primary"></i>
                    <div class="small text-muted mt-1">Bảo hành chính hãng</div>
                </div>
                <div class="col-4">
                    <i class="bi bi-arrow-repeat fs-3 text-primary"></i>
                    <div class="small text-muted mt-1">Đổi trả trong 7 ngày</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white h-100">
            <h5 class="fw-bold text-slate mb-4 border-bottom pb-2">MÔ TẢ CHI TIẾT</h5>
            <div class="product-description" style="line-height: 1.8; color: #555;">
                @Html.Raw(Model.ProductDescription?.Replace("\n", "<br/>"))
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-light h-100">
            <h5 class="fw-bold text-slate mb-4 border-bottom pb-2">THÔNG SỐ KỸ THUẬT</h5>
            @if (attributes?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-borderless mb-0">
                        @foreach (var attr in attributes)
                        {
                            <tr>
                                <td class="py-2 text-muted small w-50">@attr.AttributeName:</td>
                                <td class="py-2 fw-bold small">@attr.AttributeValue</td>
                            </tr>
                        }
                    </table>
                </div>
            }
            else
            {
                <p class="small text-muted italic">Đang cập nhật thông số...</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeQty(num) {
            let input = $("#detailQty");
            let val = parseInt(input.val()) + num;
            if (val >= 1) input.val(val);
        }

        function handleAddToCart() {
            let id = "@Model.ProductID";
            let qty = $("#detailQty").val();
            // Gọi hàm AJAX từ Layout
            if(typeof addToCart === 'function') {
                addToCart(id, qty);
            }
        }
    </script>
}