@using SV22T1020350.Admin
@{
    // Lấy thông tin người dùng đang đăng nhập từ Cookie
    var userData = User.GetUserData();
}

<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>
        </ul>

        <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    <img src="~/images/employees/@(string.IsNullOrEmpty(userData?.Photo) ? "nophoto.png" : userData.Photo)"
                         class="user-image rounded-circle shadow" alt="User Image" />

                    <span class="d-none d-md-inline fw-semibold">@(userData?.DisplayName ?? "Lê Đức Dũng")</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end border-0 shadow">
                    <li class="user-header text-bg-primary">
                        <img src="~/images/employees/@(string.IsNullOrEmpty(userData?.Photo) ? "nophoto.png" : userData.Photo)"
                             class="rounded-circle shadow" alt="User Image" />
                        <p>
                            @(userData?.DisplayName ?? "Lê Đức Dũng")
                            <small class="mt-1">Vai trò: @(userData?.Roles?.FirstOrDefault() ?? "Nhân viên")</small>
                        </p>
                    </li>

                    <li class="user-footer bg-light">
                        <a href="~/Account/ChangePassword" class="btn btn-default btn-flat border rounded"><i class="bi bi-key"></i> Đổi mật khẩu</a>
                        <a href="~/Account/Logout" class="btn btn-danger btn-flat float-end rounded"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</nav>