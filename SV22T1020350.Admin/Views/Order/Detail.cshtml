@model SV22T1020350.Admin.Models.OrderDetailModel
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {
    <div class="btn-group">
        @if (Model.Order?.Status == OrderStatusEnum.New || Model.Order?.Status == OrderStatusEnum.Accepted || Model.Order?.Status == OrderStatusEnum.Shipping)
        {
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-gear me-1"></i> Xử lý</button>
            <ul class="dropdown-menu">
                @if (Model.Order.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.Order.OrderID">Duyệt chấp nhận</a></li>
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.Order.OrderID">Từ chối đơn hàng</a></li>
                }
                @if (Model.Order.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.Order.OrderID">Chuyển giao hàng</a></li>
                }
                @if (Model.Order.Status == OrderStatusEnum.Shipping)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.Order.OrderID">Giao thành công</a></li>
                }
                @if (Model.Order.Status == OrderStatusEnum.New || Model.Order.Status == OrderStatusEnum.Accepted)
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-warning open-modal" href="~/Order/Cancel/@Model.Order.OrderID">Hủy đơn hàng</a></li>
                }
            </ul>
        }
    </div>
    @if (Model.Order?.Status == OrderStatusEnum.New)
    {
        <a href="~/Order/Edit/@Model.Order.OrderID" class="btn btn-info ms-1"><i class="bi bi-pencil-square"></i> Sửa</a>
    }
    @if (Model.Order?.Status == OrderStatusEnum.New || Model.Order?.Status == OrderStatusEnum.Cancelled || Model.Order?.Status == OrderStatusEnum.Rejected)
    {
        <a href="~/Order/Delete/@Model.Order.OrderID" class="btn btn-danger ms-1 open-modal"><i class="bi bi-trash"></i> Xóa</a>
    }
    <a href="~/Order" class="btn btn-secondary ms-1">Quay lại</a>
}

@* ... Giữ nguyên các phần thông tin khách hàng ở giữa ... *@

<div class="card card-secondary card-outline mt-3">
    <div class="card-header"><h5 class="card-title mb-0">Danh sách mặt hàng</h5></div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary text-center">
                <tr><th>STT</th><th>Tên hàng</th><th>ĐVT</th><th>SL</th><th>Giá</th><th>Thành tiền</th><th style="width:100px"></th></tr>
            </thead>
            <tbody>
                @{
                    int stt = 1; decimal total = 0;
                }
                @foreach (var item in Model.Details)
                {
                    total += item.TotalPrice;
                    <tr>
                        <td class="text-center">@(stt++)</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end fw-bold">@item.TotalPrice.ToString("N0")</td>
                        <td class="text-center">
                            @if (Model.Order?.Status == OrderStatusEnum.New)
                            {
                                <a href="~/Order/EditCartItem/@Model.Order.OrderID?productId=@item.ProductID" class="btn btn-xs btn-primary open-modal"><i class="bi bi-pencil"></i></a>
                                <a href="~/Order/DeleteCartItem/@Model.Order.OrderID?productId=@item.ProductID" class="btn btn-xs btn-danger open-modal ms-1"><i class="bi bi-trash"></i></a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr><th colspan="5" class="text-end">Tổng cộng:</th><th class="text-end text-danger">@total.ToString("N0")</th><th></th></tr>
            </tfoot>
        </table>
    </div>
</div>