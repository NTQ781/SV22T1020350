@{
    Layout = null;
}
<form action="~/Order/Delete/@ViewBag.OrderId" method="post" class="ajax-form">
    <div class="modal-header text-bg-danger">
        <strong class="modal-title">Xóa đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-exclamation-octagon me-2"></i> Bạn có chắc chắn muốn xóa đơn hàng này? Thao tác này không thể hoàn tác!
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-danger">Đồng ý xóa</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>