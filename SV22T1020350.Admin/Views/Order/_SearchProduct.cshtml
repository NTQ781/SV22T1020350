@model IEnumerable<SV22T1020350.Models.Catalog.Product>
@{
    Layout = null;
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center mt-3">
        Không tìm thấy mặt hàng nào phù hợp!
    </div>
}
else
{
    foreach (var item in Model)
    {
        <form method="post" action="/Order/AddToCart" class="form-add-to-cart border rounded p-2 mb-2 bg-light shadow-sm">
            <input type="hidden" name="ProductID" value="@item.ProductID" />
            <input type="hidden" name="ProductName" value="@item.ProductName" />
            <input type="hidden" name="Unit" value="@item.Unit" />
            <input type="hidden" name="Photo" value="@item.Photo" />

            <strong class="text-primary d-block mb-1">@item.ProductName</strong>

            <div class="row mt-2 align-items-center">
                <div class="col-4 text-center">
                    <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "noproduct.png" : item.Photo)"
                         class="img-fluid border rounded bg-white" style="max-height:80px; object-fit: cover;" />
                </div>
                <div class="col-8">
                    <div class="row g-2 align-items-center">
                        <div class="col-7">
                            <label class="form-label mb-0 small text-muted">Giá bán</label>
                            <input type="text" name="SalePrice" class="form-control form-control-sm money-input text-end fw-bold text-danger" value="@item.Price.ToString("0")" />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0 small text-muted">Số lượng</label>
                            <input type="number" name="Quantity" min="1" value="1" class="form-control form-control-sm text-center" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-success mt-2 w-100">
                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }
}