@{
    Layout = null;
}
<form action="~/Order/Cancel/@ViewBag.OrderId" method="post" class="ajax-form">
    <div class="modal-header text-bg-warning">
        <strong class="modal-title">Xác nhận hủy đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i> Bạn có thực sự muốn <strong>Hủy</strong> đơn hàng này?
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-warning">Xác nhận hủy</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>