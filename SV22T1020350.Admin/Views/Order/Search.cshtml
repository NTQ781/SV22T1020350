@model SV22T1020350.Models.Common.PagedResult<SV22T1020350.Models.Sales.OrderViewInfo>
@{
    Layout = null;
}

<div class="mb-2 text-muted">Danh sách này có <strong>@Model.RowCount</strong> đơn hàng</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>Ngày đặt</th>
                    <th class="text-start">Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Nhân viên phụ trách</th>
                    <th class="text-end">Tổng tiền</th>
                    <th style="width:140px;">Trạng thái</th>
                    <th style="width:50px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.CustomerName</td>
                        <td class="text-center">@item.CustomerPhone</td>
                        <td>@item.EmployeeName</td>
                        <td class="text-end fw-bold text-danger">@item.TotalValue.ToString("N0")</td>
                        <td class="text-center">
                            @{
                                string badgeClass = item.Status switch
                                {
                                    OrderStatusEnum.New => "bg-warning text-dark",
                                    OrderStatusEnum.Accepted => "bg-info",
                                    OrderStatusEnum.Shipping => "bg-primary",
                                    OrderStatusEnum.Completed => "bg-success",
                                    _ => "bg-danger"
                                };
                            }
                            <span class="badge @badgeClass">@item.Status.GetDescription()</span>
                        </td>
                        <td class="text-center">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-info" title="Chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer bg-white">
            <ul class="pagination pagination-sm m-0 justify-content-center">
                @foreach (var p in Model.GetDisplayPages())
                {
                    <li class="page-item @(p.IsCurrent ? "active shadow-sm" : "") @(p.IsEllipsis ? "disabled" : "")">
                        @if (p.IsEllipsis)
                        {
                            <span class="page-link">...</span>
                        }
                        else
                        {
                            <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                        }
                    </li>
                }
            </ul>
        </div>
    }
</div>