@model SV22T1020350.Models.Sales.Order
@{
    ViewBag.Title = "Chỉnh sửa đơn hàng";
}

<div class="card card-primary card-outline">
    <form action="~/Order/Edit" method="post">
        <input type="hidden" name="OrderID" value="@Model.OrderID" />
        <div class="card-body">
            <div class="mb-3">
                <label class="fw-bold">Khách hàng</label>
                <select name="CustomerID" class="form-select select2">
                    @foreach (var c in ViewBag.Customers)
                    {
                        <option value="@c.CustomerID" selected="@(c.CustomerID == Model.CustomerID)">@c.CustomerName</option>
                    }
                </select>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Tỉnh thành</label>
                    <select name="DeliveryProvince" class="form-select select2">
                        @foreach (var p in ViewBag.Provinces)
                        {
                            <option value="@p.ProvinceName" selected="@(p.ProvinceName == Model.DeliveryProvince)">@p.ProvinceName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Địa chỉ nhận hàng</label>
                    <input type="text" name="DeliveryAddress" class="form-control" value="@Model.DeliveryAddress" />
                </div>
            </div>
        </div>
        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
            <a href="~/Order/Detail/@Model.OrderID" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>$(document).ready(function() { $('.select2').select2(); });</script>
}