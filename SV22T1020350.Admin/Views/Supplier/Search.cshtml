@model PagedResult<Supplier>
@{
    Layout = null;
}

<div class="mb-2 text-muted">Danh sách này có <strong>@Model.RowCount</strong> nhà cung cấp</div>
<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên nhà cung cấp</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.SupplierName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td class="text-center">
                            <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                            <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                <li class="page-item @(p.IsCurrent ? "active" : "")">
                    @if (p.IsEllipsis)
                    {
                        <span class="page-link">...</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                    }
                </li>
            }
        </ul>
    </div>
</div>