@model PagedResult<Category>

@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> loại hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên loại hàng</th>
                    <th>Mô tả</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="align-middle">@item.CategoryName</td>
                        <td class="align-middle">@item.Description</td>
                        <td class="text-center text-nowrap">
                            <a href="~/Category/Edit/@item.CategoryID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Category/Delete/@item.CategoryID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                <li class="page-item @(p.IsCurrent ? "active" : "")">
                    @if (p.IsEllipsis)
                    {
                        <span class="page-link">...</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    }
                </li>
            }
        </ul>
    </div>
</div>