@model IEnumerable<SV22T1020350.Models.Catalog.ProductPhoto>
@{
    Layout = null;
}
<div class="card card-info card-outline mt-4">
    <div class="card-header d-flex align-items-center">
        <h6 class="mb-0 fw-bold"><i class="bi bi-images me-2"></i> Thư viện ảnh</h6>
        <a class="btn btn-sm btn-primary ms-auto" href="~/Product/CreatePhotos/@ViewData["ProductID"]">
            <i class="bi bi-plus-circle"></i> Thêm ảnh
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-light text-center">
                <tr><th style="width:120px">Ảnh</th><th>Mô tả / Thứ tự</th><th style="width:100px">Thao tác</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center"><img src="/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" class="img-thumbnail" style="max-height:70px;" /></td>
                        <td>@item.Description <br /><small class="text-muted">Thứ tự: @item.DisplayOrder</small></td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-primary" href="~/Product/EditPhotos/@item.ProductID?photoId=@item.PhotoID"><i class="bi bi-pencil"></i></a>
                            <a class="btn btn-sm btn-outline-danger ms-1" href="~/Product/DeletePhotos/@item.ProductID?photoId=@item.PhotoID"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>