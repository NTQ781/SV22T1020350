@model SV22T1020350.Models.Catalog.Product
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i> @ViewBag.Title
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/Save" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="ProductName" value="@Model.ProductName" required autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select class="form-select" name="CategoryID" required>
                                <option value="">-- Chọn loại hàng --</option>
                                @foreach (var cat in SV22T1020350.BusinessLayers.CatalogDataService.ListCategoriesAsync(new SV22T1020350.Models.Common.PaginationSearchInput { PageSize = 0 }).Result.DataItems)
                                {
                                    if (cat.CategoryID == Model.CategoryID)
                                    {
                                        <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.CategoryID">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" name="SupplierID" required>
                                <option value="">-- Chọn nhà cung cấp --</option>
                                @foreach (var sup in SV22T1020350.BusinessLayers.PartnerDataService.ListSuppliersAsync(new SV22T1020350.Models.Common.PaginationSearchInput { PageSize = 0 }).Result.DataItems)
                                {
                                    if (sup.SupplierID == Model.SupplierID)
                                    {
                                        <option value="@sup.SupplierID" selected>@sup.SupplierName</option>
                                    }
                                    else
                                    {
                                        <option value="@sup.SupplierID">@sup.SupplierName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text" class="form-control" name="Unit" value="@Model.Unit" required />
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="number" class="form-control" name="Price" value="@Model.Price" min="0" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="IsSelling" value="true" id="IsSelling" @(Model.IsSelling ? "checked" : "") />
                                <label class="form-check-label" for="IsSelling">Đang bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            <input type="file" class="form-control" name="uploadPhoto" accept="image/*" onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2">
                                <img id="imgPreview" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)" class="img-thumbnail" style="max-height: 160px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" rows="3" name="ProductDescription">@Model.ProductDescription</textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div> 

@{
    if (Model.ProductID > 0)
    {
        ViewData["ProductID"] = Model.ProductID;
        // Chỉ hiện Thư viện ảnh khi sửa sản phẩm (đã có ID)
        await Html.RenderPartialAsync("ListPhotos", ViewBag.Photos as IEnumerable<SV22T1020350.Models.Catalog.ProductPhoto>);
        await Html.RenderPartialAsync("ListAttributes", ViewBag.Attributes as IEnumerable<SV22T1020350.Models.Catalog.ProductAttribute>);
    }
}