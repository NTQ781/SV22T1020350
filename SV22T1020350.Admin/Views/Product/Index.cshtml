@model SV22T1020350.Models.Catalog.ProductSearchInput
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Bổ sung</a>
}

<div class="card card-primary card-outline">
    <div class="card-body">
        <form id="formSearch" action="~/Product/Search" method="get" data-target="searchResult">
            <input type="hidden" name="PageSize" value="@Model.PageSize" />
            <div class="row g-2">
                <div class="col-md-3">
                    <label>Loại hàng</label>
                    <select class="form-select" name="CategoryID">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var c in ViewBag.Categories)
                        {
                            <option value="@c.CategoryID" selected="@(c.CategoryID == Model.CategoryID)">@c.CategoryName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label>Nhà cung cấp</label>
                    <select class="form-select" name="SupplierID">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var s in ViewBag.Suppliers)
                        {
                            <option value="@s.SupplierID" selected="@(s.SupplierID == Model.SupplierID)">@s.SupplierName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label>Khoảng giá</label>
                    <div class="input-group">
                        <input type="text" name="MinPrice" class="form-control money-input" value="@Model.MinPrice" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="MaxPrice" class="form-control money-input" value="@Model.MaxPrice" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label>Tìm kiếm</label>
                    <div class="input-group">
                        <input type="text" name="SearchValue" class="form-control" value="@Model.SearchValue" placeholder="Tên mặt hàng..." />
                        <button class="btn btn-info" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                </div>
            </div>
        </form>
        <div id="searchResult" class="mt-3"></div>
    </div>
</div>

@section Scripts {
    <script>
        function doSearch(page) {
            paginationSearch(null, document.getElementById("formSearch"), page);
        }
        $(document).ready(function() {
            $("#formSearch").submit(function(e) { paginationSearch(e, this, 1); });
            doSearch(@Model.Page); // Tự động load trang từ Session
        });
    </script>
}