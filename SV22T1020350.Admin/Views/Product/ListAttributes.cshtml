@model IEnumerable<SV22T1020350.Models.Catalog.ProductAttribute>
@{
    Layout = null;
}
<div class="card card-success card-outline mt-4">
    <div class="card-header d-flex align-items-center">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-check me-2"></i> Thuộc tính sản phẩm</h6>
        <a class="btn btn-sm btn-primary ms-auto" href="~/Product/CreateAttributes/@ViewData["ProductID"]">
            <i class="bi bi-plus-circle"></i> Thêm thuộc tính
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-light text-center">
                <tr><th>Tên thuộc tính</th><th>Giá trị</th><th style="width:80px">Thứ tự</th><th style="width:100px">Thao tác</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">@item.AttributeName</td>
                        <td>@item.AttributeValue</td>
                        <td class="text-center">@item.DisplayOrder</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-primary" href="~/Product/EditAttributes/@item.ProductID?attributeId=@item.AttributeID"><i class="bi bi-pencil"></i></a>
                            <a class="btn btn-sm btn-outline-danger ms-1" href="~/Product/DeleteAttributes/@item.ProductID?attributeId=@item.AttributeID"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>