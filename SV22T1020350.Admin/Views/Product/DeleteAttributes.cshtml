@model SV22T1020350.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Xóa thuộc tính";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash"></i> Xóa thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header"><h3 class="card-title"><i class="bi bi-list-check"></i> Xác nhận xóa thuộc tính</h3></div>
    <div class="card-body">
        <form id="formDelete" method="post" action="~/Product/DeleteAttributesConfirm/@Model.ProductID?attributeId=@Model.AttributeID">
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i> Bạn có chắc chắn muốn xóa thuộc tính này không?
            </div>
            <dl class="row mb-0">
                <dt class="col-sm-3">Tên thuộc tính:</dt>
                <dd class="col-sm-9 fw-bold text-primary">@Model.AttributeName</dd>
                <dt class="col-sm-3">Giá trị:</dt>
                <dd class="col-sm-9">@Model.AttributeValue</dd>
                <dt class="col-sm-3">Thứ tự hiển thị:</dt>
                <dd class="col-sm-9">@Model.DisplayOrder</dd>
            </dl>
        </form>
    </div>
</div>