@model SV22T1020350.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger"><i class="bi bi-trash"></i> XÁC NHẬN XÓA</button>
    <a href="/Product" class="btn btn-secondary ms-1">HỦY BỎ</a>
}
<div class="card card-danger card-outline">
    <div class="card-body">
        <form id="formDelete" action="/Product/DeleteConfirm/@Model.ProductID" method="post">
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa <strong>@Model.ProductName</strong>?
            </div>
            <div class="row">
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">Giá bán:</dt>
                        <dd class="col-sm-8 text-danger fw-bold">@Model.Price.ToString("N0") đ</dd>
                        <dt class="col-sm-4">Đơn vị tính:</dt>
                        <dd class="col-sm-8">@Model.Unit</dd>
                    </dl>
                </div>
                <div class="col-md-4 text-center">
                    <img src="/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "noproduct.png" : Model.Photo)"
                         class="img-thumbnail" style="max-height: 200px;" />
                </div>
            </div>
        </form>
    </div>
</div>