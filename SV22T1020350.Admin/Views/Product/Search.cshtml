@model SV22T1020350.Models.Common.PagedResult<SV22T1020350.Models.Catalog.Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary text-center">
                <tr>
                    <th style="width: 80px;">Ảnh</th>
                    <th>Tên mặt hàng</th>
                    <th style="width: 100px;">Đơn vị</th>
                    <th style="width: 130px;">Giá bán</th>
                    <th style="width: 120px;">Trạng thái</th>
                    <th class="text-center" style="width: 100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center align-middle">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/noproduct.png") : Url.Content($"~/images/products/{item.Photo}"))"
                                 style="width:50px; height:50px; object-fit:cover; border-radius: 5px;"
                                 alt="@item.ProductName" />
                        </td>
                        <td class="align-middle">
                            <div class="fw-bold text-primary">@item.ProductName</div>
                            <small class="text-muted d-block text-truncate" style="max-width: 400px;">
                                @item.ProductDescription
                            </small>
                        </td>
                        <td class="text-center align-middle">@item.Unit</td>
                        <td class="text-end align-middle fw-bold text-danger">
                            @item.Price.ToString("N0") <small>đ</small>
                        </td>
                        <td class="text-center align-middle">
                            @if (item.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ngừng bán</span>
                            }
                        </td>
                        <td class="text-center text-nowrap align-middle">
                            <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary" title="Cập nhật">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (Model.RowCount == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center p-4 text-muted">
                            Không tìm thấy mặt hàng nào phù hợp với yêu cầu.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* PHẦN PHÂN TRANG *@
    @if (Model.PageCount > 1)
    {
        <div class="card-footer bg-white border-top-0">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                @foreach (var p in Model.GetDisplayPages())
                {
                    <li class="page-item @(p.IsCurrent ? "active shadow-sm" : "")">
                        @if (p.IsEllipsis)
                        {
                            <span class="page-link">...</span>
                        }
                        else
                        {
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        }
                    </li>
                }
            </ul>
        </div>
    }
</div>